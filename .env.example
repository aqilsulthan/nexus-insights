# ═══════════════════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# DIFY WORKFLOW (primary AI backend)
# ═══════════════════════════════════════════════════════════════

# Your Dify Workflow app API key
# Path: Dify → Your App → Settings → API Access → API Key
DIFY_WORKFLOW_API_KEY=app-xxxxxxxxxxxxxxxxxxxx

# Your Dify Knowledge Base (Dataset) ID — for document uploads
# Path: Dify → Knowledge → Your Dataset → copy ID from the URL
# URL format: /datasets/<DIFY_DATASET_ID>/documents
DIFY_DATASET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Dify base URL
# Cloud: https://api.dify.ai/v1  (default)
# Self-hosted: http://your-server/v1
DIFY_BASE_URL=https://api.dify.ai/v1

# ───────────────────────────────────────────────────────────────
# Your Dify Workflow MUST have these variable names:
#
#   START node inputs:
#     question      (string) — user's question
#     chat_history  (string) — prior turns, optional
#     topic_filter  (string) — category filter, optional
#
#   END node outputs:
#     answer      (string) — the AI response
#     references  (string) — JSON array of reference cards, optional
# ───────────────────────────────────────────────────────────────
